# ── OpenAI ───────────────────────────────────────────────
# 取得位置：https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ── LINE Messaging API ────────────────────────────────────
# 取得位置：https://developers.line.biz/console/
# 1. 建立 Provider → 建立 Messaging API Channel
# 2. Channel settings → Issue channel access token
LINE_CHANNEL_ACCESS_TOKEN=...

# 3. 推播目標（擇一填入）
#    個人 User ID：LINE 官方帳號加好友後，Webhook 可取得；或到 developers 頁面查詢
#    群組 Group ID：Bot 加入群組後，由 Webhook 事件取得
LINE_USER_ID=U...
