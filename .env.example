# ── OpenAI ───────────────────────────────────────────────
# 取得位置：https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ── Telegram Bot ─────────────────────────────────────────
# 1. 在 Telegram 搜尋 @BotFather，建立 Bot 取得 Token
# 2. Chat ID 可從 @userinfobot 取得，支援逗號分隔多個目標
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
TELEGRAM_CHAT_ID=123456789

# ── 排程設定（選填）────────────────────────────────────────
# Cron 表達式，預設每日 08:00（Asia/Taipei）
CRON_SCHEDULE=0 8 * * *
